# /etc/cascade/relay.env — environment file for the cascade-relay systemd unit.
#
# Copy this file to /etc/cascade/relay.env, fill in CASCADE_RELAY_SHARED_SECRET,
# and restrict its permissions so the secret is not world-readable:
#
#   cp relay.env.example /etc/cascade/relay.env
#   chmod 600 /etc/cascade/relay.env
#   chown cascade-relay: /etc/cascade/relay.env
#
# Then start the service: systemctl enable --now cascade-relay

# ── Required ────────────────────────────────────────────────────────────────

# 64-character hexadecimal HMAC shared secret (32 bytes decoded).
# Generate with: openssl rand -hex 32
# Every peer that will use this relay, and any announce server co-hosted here,
# must be configured with the same secret.
CASCADE_RELAY_SHARED_SECRET=REPLACE_WITH_64_HEX_CHARS

# ── Optional ────────────────────────────────────────────────────────────────

# Bind address for the byte-pipe listener.  Peers connect here.
# Default: 0.0.0.0:9999
#CASCADE_RELAY_LISTEN=0.0.0.0:9999

# Bind address for the /metrics (Prometheus) and /health (liveness) HTTP
# endpoint.  Restrict to loopback if you scrape metrics locally; expose on a
# LAN interface if your Prometheus is remote.  When unset, neither endpoint
# is available.
#CASCADE_RELAY_METRICS=127.0.0.1:9998

# Bind address for the announce/lookup directory endpoint.
# Requires the relay binary to have been built with --features announce.
# When unset the announce directory is disabled; the relay serves only the
# byte-pipe.
#CASCADE_RELAY_ANNOUNCE=127.0.0.1:9997
