#!/bin/bash
# Pre-commit hook: reject merge commits on main, auto-fix formatting.

set -euo pipefail

# Reject merge commits on main branch.
branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
if [[ "$branch" == "main" || "$branch" == "origin-main" ]]; then
    if test -f "$(git rev-parse --git-dir)/MERGE_HEAD"; then
        echo "error: merge commits are forbidden on $branch. Use rebase instead."
        exit 1
    fi
fi

# The toolchain is pinned via rust-toolchain.toml at the repo root.
# No hardcoded PATH or RUSTUP_TOOLCHAIN overrides needed.

# Snapshot staged Rust files before formatting.
staged_rs=()
while IFS= read -r f; do
    [[ -n "$f" ]] && staged_rs+=("$f")
done < <(git diff --cached --name-only -- '*.rs')

cargo fmt

# Re-stage any of those files that cargo fmt reformatted.
for f in "${staged_rs[@]+"${staged_rs[@]}"}"; do
    git diff --quiet -- "$f" || git add -- "$f"
done
