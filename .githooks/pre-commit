#!/bin/bash
# Pre-commit hook: auto-fix formatting.
# Runs cargo fmt and stages the changes so the commit proceeds cleanly.

set -euo pipefail

# Use the mise-managed toolchain directly.
export PATH="$HOME/.rustup/toolchains/1.89.0-aarch64-apple-darwin/bin:$PATH"
export RUSTUP_TOOLCHAIN=1.89.0-aarch64-apple-darwin

cargo fmt

# Stage any formatting changes so they're included in this commit.
git diff --name-only --diff-filter=M -- '*.rs' | xargs -r git add
