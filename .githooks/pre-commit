#!/bin/bash
# Pre-commit hook: reject merge commits on main, auto-fix formatting.

set -euo pipefail

# Reject merge commits on main branch.
branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
if [[ "$branch" == "main" || "$branch" == "origin-main" ]]; then
    if test -f "$(git rev-parse --git-dir)/MERGE_HEAD"; then
        echo "error: merge commits are forbidden on $branch. Use rebase instead."
        exit 1
    fi
fi

# Use the mise-managed toolchain directly.
export PATH="$HOME/.rustup/toolchains/1.89.0-aarch64-apple-darwin/bin:$PATH"
export RUSTUP_TOOLCHAIN=1.89.0-aarch64-apple-darwin

cargo fmt

# Stage any formatting changes so they're included in this commit.
git diff --name-only --diff-filter=M -- '*.rs' | xargs -r git add
