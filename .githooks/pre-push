#!/bin/bash
# Pre-push hook: run all quality gates.
# clippy (warnings as errors), tests, and format verification.
#
# The toolchain is pinned via rust-toolchain.toml at the repo root.
# No hardcoded PATH or RUSTUP_TOOLCHAIN overrides needed.

set -euo pipefail

# Reject merge commits being pushed to main.
while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$remote_ref" == refs/heads/main || "$remote_ref" == refs/heads/origin-main ]]; then
        range="${remote_sha}..${local_sha}"
        # Handle new branch (no common ancestor yet): check all commits.
        if git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
            range="$remote_sha..$local_sha"
        else
            range="$local_sha"
        fi
        merges=$(git rev-list --merges "$range" 2>/dev/null || true)
        if [[ -n "$merges" ]]; then
            echo "error: merge commits are forbidden on ${remote_ref#refs/heads/}. Use rebase instead."
            echo "offending commits:"
            git log --oneline --merges "$range"
            exit 1
        fi
    fi
done

echo "Verifying Rust toolchain..."

# Parse the pinned channel from rust-toolchain.toml.
PINNED_CHANNEL=$(grep -E '^channel = ' rust-toolchain.toml | head -1 | sed -E 's/^channel = "(.+)"/\1/')
if [[ -z "$PINNED_CHANNEL" ]]; then
    echo "warning: could not parse channel from rust-toolchain.toml; skipping toolchain check"
else
    # rust-toolchain.toml is only auto-respected by rustup. If cargo isn't
    # rustup-managed, the version on PATH is whatever the developer
    # installed — typically Homebrew, which drifts from CI.
    CARGO_PATH=$(command -v cargo)
    if [[ -z "$CARGO_PATH" ]]; then
        echo "error: cargo not found on PATH" >&2
        exit 1
    fi

    # Only semantic versions (X.Y.Z) have a checkable cargo --version string.
    # Symbolic channels (stable, beta, nightly, nightly-YYYY-MM-DD) get an
    # info line and skip the exact-version check.
    is_semantic_channel=false
    if [[ "$PINNED_CHANNEL" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        is_semantic_channel=true
    fi

    rustup_handled=false
    if command -v rustup >/dev/null 2>&1; then
        # Query rustup's installed-toolchain list directly. This is the
        # truth source — `cargo --version` lags rustup until the first
        # invocation in the directory, which makes it misleading on a
        # fresh box where the pinned channel hasn't yet been installed.
        if RUSTUP_LIST=$(rustup toolchain list --verbose 2>/dev/null); then
            rustup_handled=true
            # Anchor the match: rustup names a toolchain either "X.Y.Z" or
            # "X.Y.Z-<host-triple>", so the channel must appear at the start
            # of a line followed by EOL, hyphen, or whitespace. An
            # unanchored grep -qF would let "1.9.6" match "1.96.0-...".
            ESCAPED_CHANNEL=$(echo "$PINNED_CHANNEL" | sed 's/\./\\./g')
            if ! echo "$RUSTUP_LIST" | grep -qE "^${ESCAPED_CHANNEL}(-|[[:space:]]|$)"; then
                echo "rustup: pinned channel ${PINNED_CHANNEL} is not installed; installing now"
                if ! rustup install "$PINNED_CHANNEL"; then
                    echo "error: rustup failed to install ${PINNED_CHANNEL}" >&2
                    exit 1
                fi
            fi
        fi
    fi

    if [[ "$rustup_handled" == false ]]; then
        # No working rustup. The cargo on PATH is whatever the system installed,
        # and rust-toolchain.toml is not auto-respected.
        if [[ "$is_semantic_channel" == false ]]; then
            echo "channel ${PINNED_CHANNEL} selected — toolchain version not verified"
        else
            CARGO_VERSION_STRING=$(cargo --version 2>&1)
            # Anchor the match at the start of the version output: the
            # output is reliably `cargo X.Y.Z (...)`. Escaping the dots
            # in the channel keeps the regex precise — without escaping,
            # `1.96.0` would also match `1x96x0`-like strings.
            ESCAPED_CHANNEL=$(echo "$PINNED_CHANNEL" | sed 's/\./\\./g')
            if ! echo "$CARGO_VERSION_STRING" | grep -qE "^cargo ${ESCAPED_CHANNEL} \("; then
                cat >&2 <<EOF
error: local toolchain does not match the pinned channel.
       pinned (rust-toolchain.toml): ${PINNED_CHANNEL}
       actual (cargo on PATH):       ${CARGO_VERSION_STRING}

       Without rustup, this hook runs gates against a different toolchain
       than CI. To fix:
           1. Install rustup:   https://rustup.rs/
           2. The pinned toolchain installs automatically on next cargo invocation.
           3. Optionally remove the Homebrew/system rust to avoid PATH ambiguity.
EOF
                exit 1
            fi
        fi
    fi
fi

echo "Checking formatting..."
if ! cargo fmt --check 2>&1; then
    echo ""
    echo "cargo fmt found differences. Run 'cargo fmt' and amend the commit."
    exit 1
fi

echo "Running clippy..."
if ! cargo clippy --workspace 2>&1; then
    echo ""
    echo "clippy found issues. Fix before pushing."
    exit 1
fi

echo "Running tests..."
if ! cargo test --workspace 2>&1; then
    echo ""
    echo "Tests failed. Fix before pushing."
    exit 1
fi

echo "All checks passed."
echo "Note: platform-specific code (cfg(not(target_os = \"macos\"))) is only linted on CI."
echo "      The macOS runner in CI will catch platform-gated issues for both OSes."
