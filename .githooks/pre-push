#!/bin/bash
# Pre-push hook: run all quality gates.
# clippy (warnings as errors), tests, and format verification.
#
# The toolchain is pinned via rust-toolchain.toml at the repo root.
# No hardcoded PATH or RUSTUP_TOOLCHAIN overrides needed.

set -euo pipefail

# Reject merge commits being pushed to main.
while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$remote_ref" == refs/heads/main || "$remote_ref" == refs/heads/origin-main ]]; then
        range="${remote_sha}..${local_sha}"
        # Handle new branch (no common ancestor yet): check all commits.
        if git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
            range="$remote_sha..$local_sha"
        else
            range="$local_sha"
        fi
        merges=$(git rev-list --merges "$range" 2>/dev/null || true)
        if [[ -n "$merges" ]]; then
            echo "error: merge commits are forbidden on ${remote_ref#refs/heads/}. Use rebase instead."
            echo "offending commits:"
            git log --oneline --merges "$range"
            exit 1
        fi
    fi
done

echo "Verifying Rust toolchain..."

# Parse the pinned channel from rust-toolchain.toml.
PINNED_CHANNEL=$(grep -E '^channel = ' rust-toolchain.toml | head -1 | sed -E 's/^channel = "(.+)"/\1/')
if [[ -z "$PINNED_CHANNEL" ]]; then
    echo "warning: could not parse channel from rust-toolchain.toml; skipping toolchain check"
else
    # rust-toolchain.toml is only auto-respected by rustup. If cargo isn't
    # rustup-managed, the version on PATH is whatever the developer
    # installed — typically Homebrew, which drifts from CI.
    CARGO_PATH=$(command -v cargo)
    if [[ -z "$CARGO_PATH" ]]; then
        echo "error: cargo not found on PATH" >&2
        exit 1
    fi

    # Detect rustup by checking if `rustup` exists and resolves cargo.
    if command -v rustup >/dev/null 2>&1; then
        # rustup is installed — it respects rust-toolchain.toml automatically.
        CARGO_VERSION=$(cargo --version 2>&1)
        if ! echo "$CARGO_VERSION" | grep -qF "${PINNED_CHANNEL%%-*}"; then
            echo "warning: cargo version does not contain pinned channel ${PINNED_CHANNEL}"
            echo "         got: $CARGO_VERSION"
            echo "         continuing — rustup should auto-install on first invocation"
        fi
    else
        # No rustup. The cargo on PATH is whatever the system installed.
        CARGO_VERSION=$(cargo --version 2>&1)
        if ! echo "$CARGO_VERSION" | grep -qF "${PINNED_CHANNEL%%-*}"; then
            cat >&2 <<EOF
error: local toolchain does not match the pinned channel.
       pinned (rust-toolchain.toml): ${PINNED_CHANNEL}
       actual (cargo on PATH):       ${CARGO_VERSION}

       Without rustup, this hook runs gates against a different toolchain
       than CI. To fix:
           1. Install rustup:   https://rustup.rs/
           2. The pinned toolchain installs automatically on next cargo invocation.
           3. Optionally remove the Homebrew/system rust to avoid PATH ambiguity.
EOF
            exit 1
        fi
    fi
fi

echo "Checking formatting..."
if ! cargo fmt --check 2>&1; then
    echo ""
    echo "cargo fmt found differences. Run 'cargo fmt' and amend the commit."
    exit 1
fi

echo "Running clippy..."
if ! cargo clippy --workspace 2>&1; then
    echo ""
    echo "clippy found issues. Fix before pushing."
    exit 1
fi

echo "Running tests..."
if ! cargo test --workspace 2>&1; then
    echo ""
    echo "Tests failed. Fix before pushing."
    exit 1
fi

echo "All checks passed."
echo "Note: platform-specific code (cfg(not(target_os = \"macos\"))) is only linted on CI."
echo "      The macOS runner in CI will catch platform-gated issues for both OSes."
